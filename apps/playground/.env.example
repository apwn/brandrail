# ── Brandrail playground (public) ───────────────────────────────────────────

# Where the engine API lives (server-side proxy target; never exposed to the browser)
ENGINE_URL=http://localhost:4747

# Engine API key, if the engine requires one (matches BRANDRAIL_API_KEYS there)
BRANDRAIL_API_KEY=

# Signs the session cookie. MUST be a long random string in production — anyone
# who knows it can forge sessions. Generate: `openssl rand -base64 32`
SESSION_SECRET=change-me-to-a-long-random-string

# Shared secret proving proxy→engine calls are trusted (must match the engine's
# INTERNAL_SECRET). Required when the engine is internet-facing.
INTERNAL_SECRET=

# Only enable outside Vercel when the app is directly behind a trusted reverse
# proxy that overwrites X-Forwarded-For. Untrusted forwarded headers are ignored.
# TRUST_PROXY_HEADERS=1

# Hosted MCP hardening. Origins are denied unless they match the app origin or
# this comma-separated allowlist. Add OAuth 2.1 authorization-server issuers
# after configuring your provider; API-key bearer auth remains the fallback.
# MCP_ALLOWED_ORIGINS=https://chatgpt.com,https://claude.ai
# MCP_AUTHORIZATION_SERVERS=https://auth.example.com

# Magic-link sign-in emails — Resend (https://resend.com). Without a key, links
# are printed to the server console and (dev only) surfaced in the UI, so the
# whole auth flow works locally with zero setup.
RESEND_API_KEY=
# MAIL_FROM=Brandrail <sign-in@yourdomain.com>
# Required in production; canonical HTTPS origin for email, OAuth and billing links.
PUBLIC_URL=

# Optional privacy-light conversion funnel delivery. Events use a random
# session-scoped id and never include website URLs, email addresses or content.
# Without a key, structured events are written to server logs.
POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
