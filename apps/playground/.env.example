# ── Brandrail playground (public) ───────────────────────────────────────────

# Where the engine API lives (server-side proxy target; never exposed to the browser)
ENGINE_URL=http://localhost:4747

# Engine API key, if the engine requires one (matches BRANDRAIL_API_KEYS there)
BRANDRAIL_API_KEY=

# Signs the session cookie. MUST be a long random string in production — anyone
# who knows it can forge sessions. Generate: `openssl rand -base64 32`
SESSION_SECRET=change-me-to-a-long-random-string

# Shared secret proving proxy→engine calls are trusted (must match the engine's
# INTERNAL_SECRET). Required when the engine is internet-facing.
INTERNAL_SECRET=
