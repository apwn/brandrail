{
  "name": "@brandrail/mcp",
  "version": "0.1.0",
  "description": "Brandrail MCP server — 46 tools for BrandSpecs, deterministic assets, durable runs, review, publishing, analytics, and audit.",
  "license": "MIT",
  "homepage": "https://github.com/apwn/brandrail#readme",
  "bugs": { "url": "https://github.com/apwn/brandrail/issues" },
  "repository": { "type": "git", "url": "git+https://github.com/apwn/brandrail.git", "directory": "packages/mcp" },
  "engines": { "node": ">=20" },
  "type": "module",
  "bin": {
    "brandrail-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs');const f='dist/index.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'));fs.chmodSync(f,0o755)\"",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@brandrail/sdk": "workspace:*",
    "@brandrail/spec": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
