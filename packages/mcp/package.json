{
  "name": "@brandrail/mcp",
  "version": "0.1.0",
  "description": "Brandrail MCP server — gives agents compile_brand, render_assets, get_spec and diff_spec tools. On-brand, on autopilot.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "brandrail-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs');const f='dist/index.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'));fs.chmodSync(f,0o755)\"",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@brandrail/sdk": "workspace:*",
    "@brandrail/spec": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
