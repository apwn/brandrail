{
  "name": "@brandrail/spec",
  "version": "0.1.0",
  "description": "BrandSpec v0.1 — the portable, versionable, forkable brand definition format. Schema, validators, differ, forker.",
  "license": "MIT",
  "homepage": "https://github.com/apwn/brandrail#readme",
  "bugs": { "url": "https://github.com/apwn/brandrail/issues" },
  "repository": { "type": "git", "url": "git+https://github.com/apwn/brandrail.git", "directory": "packages/spec" },
  "engines": { "node": ">=20" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
